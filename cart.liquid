<main class="container">
  <section class="section">
    <div class="section-title"><span></span><h2>Your Cart</h2></div>
    {% if cart.item_count > 0 %}
      <div class="card" style="padding: 2rem;">
        <p style="margin: 0 0 1.5rem; color: var(--muted);">Review your selected timepieces before proceeding to secure checkout.</p>
        <div style="display: grid; gap: 1rem;">
          {% for item in cart.items %}
            <div style="display: flex; justify-content: space-between; gap: 1rem; padding: 1.5rem; background: rgba(255,255,255,0.03); border-radius: 24px; align-items: center;">
              <div>
                <strong>{{ item.product.title }}</strong>
                <p style="margin: 0.5rem 0 0; color: var(--muted);">{{ item.variant.title }} · Qty {{ item.quantity }}</p>
              </div>
              <div style="text-align: right;">
                <p style="margin: 0;">{{ item.quantity }} x {{ item.price | money }}</p>
                <strong>{{ item.line_price | money }}</strong>
              </div>
            </div>
          {% endfor %}
        </div>
        <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 2rem; gap: 1rem; flex-wrap: wrap;">
          <div>
            <p style="margin: 0; color: var(--muted);">Estimated total</p>
            <h3 style="margin: 0.5rem 0 0;">{{ cart.total_price | money }}</h3>
          </div>
          <a class="btn-primary" href="/checkout">Proceed to Checkout</a>
        </div>
      </div>
    {% else %}
      <div class="card" style="padding: 2rem; color: var(--muted);">
        <p>Your cart is currently empty. Explore the collection to add a luxury timepiece.</p>
      </div>
    {% endif %}
  </section>
</main>
