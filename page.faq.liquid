<main class="container">
  <section class="section">
    <div class="section-title"><span></span><h2>Frequently Asked Questions</h2></div>
    <div class="grid" style="gap: 1rem;">
      <button class="card" data-accordion="answer1" aria-expanded="false" style="text-align:left; padding: 1.75rem; border:1px solid var(--border); background: rgba(255,255,255,0.02); border-radius: 24px;">What is MQ's shipping policy?</button>
      <div id="answer1" style="max-height: 0; overflow: hidden; transition: max-height 0.25s ease;" class="card">
        <p style="margin:0; color: var(--muted);">MQ offers insured worldwide shipping with discreet packaging, tracking updates, and complimentary delivery on all orders.</p>
      </div>
      <button class="card" data-accordion="answer2" aria-expanded="false" style="text-align:left; padding: 1.75rem; border:1px solid var(--border); background: rgba(255,255,255,0.02); border-radius: 24px;">How do returns work?</button>
      <div id="answer2" style="max-height: 0; overflow: hidden; transition: max-height 0.25s ease;" class="card">
        <p style="margin:0; color: var(--muted);">Returns are accepted within 30 days on unworn watches. Our concierge team handles return logistics for a seamless experience.</p>
      </div>
      <button class="card" data-accordion="answer3" aria-expanded="false" style="text-align:left; padding: 1.75rem; border:1px solid var(--border); background: rgba(255,255,255,0.02); border-radius: 24px;">Is there a warranty?</button>
      <div id="answer3" style="max-height: 0; overflow: hidden; transition: max-height 0.25s ease;" class="card">
        <p style="margin:0; color: var(--muted);">Every MQ watch includes a two-year limited warranty covering manufacturing defects and craftsmanship issues.</p>
      </div>
      <button class="card" data-accordion="answer4" aria-expanded="false" style="text-align:left; padding: 1.75rem; border:1px solid var(--border); background: rgba(255,255,255,0.02); border-radius: 24px;">Can I customize my watch?</button>
      <div id="answer4" style="max-height: 0; overflow: hidden; transition: max-height 0.25s ease;" class="card">
        <p style="margin:0; color: var(--muted);">MQ offers bespoke requests for select collections. Contact our concierge team for customization availability and guidance.</p>
      </div>
    </div>
  </section>
</main>
